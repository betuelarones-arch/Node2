<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Estudiantes</title>
</head>
<body>
    <h1>Lista de estudiantes</h1>

    <table border="1">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Nota</th>
            </tr>
        </thead>
        <tbody>
            {{#each students}}
            <tr>
                <td>{{name}}</td>
                <td>
                    {{#if (gt grade 15)}}
                        <strong style="color: green;">{{grade}}</strong>
                    {{else}}
                        {{grade}}
                    {{/if}}
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <a href="/">Volver al inicio</a>
</body>
</html>